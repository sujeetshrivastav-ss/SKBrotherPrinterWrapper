      <PostActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Copy SPM binary-target dSYMs into archive"
               scriptText = "# Xcode does not always copy dSYMs of SPM .binaryTarget xcframeworks&#10;# into the archive. Copy any bundled *.dSYM found in resolved packages.&#10;set -e&#10;CHECKOUTS=&quot;${BUILD_DIR%Build/*}SourcePackages/checkouts&quot;&#10;[ -d &quot;$CHECKOUTS&quot; ] || exit 0&#10;mkdir -p &quot;${ARCHIVE_PATH}/dSYMs&quot;&#10;find &quot;$CHECKOUTS&quot; -name &quot;*.dSYM&quot; -path &quot;*dSYMs*&quot; -maxdepth 8 -print0 | while IFS= read -r -d &apos;&apos; d; do&#10;  cp -R &quot;$d&quot; &quot;${ARCHIVE_PATH}/dSYMs/&quot;&#10;done&#10;">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "877C93D42FF41EDD00827C3C"
                     BuildableName = "DemoBrotherApp.app"
                     BlueprintName = "DemoBrotherApp"
                     ReferencedContainer = "container:DemoBrotherApp.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PostActions>
   </ArchiveAction>
